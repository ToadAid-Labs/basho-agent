# Telegram Trading Bot Configuration
# Copy this file to .env and fill in your actual credentials

# ==========================================
# Trust Wallet API Credentials
# ==========================================
# Get your API keys from: https://portal.trustwallet.com
TWAK_ACCESS_ID=your_access_id_here
TWAK_HMAC_SECRET=your_hmac_secret_here

# Flask Backend Configuration
BACKEND_URL=http://localhost:5000
SECRET_KEY=generate-a-long-random-string-here
DASHBOARD_PASSWORD=change-me-before-use

# Paper Trading Settings
PAPER_TRADING_INITIAL_BALANCE=10000

# ── Ollama ─────────────────────────────────────────────────
# Base URL of the Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Model to use (get available models with: curl http://localhost:11434/api/tags)
OLLAMA_MODEL=your_local_model

# LLM Provider (ANTHROPIC or OLLAMA)
LLM_PROVIDER=ANTHROPIC
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI Codex provider
# Use MODEL_PROVIDER=openai-codex after running `python3 agent.py login`.
MODEL_PROVIDER=anthropic
OPENAI_CODEX_MODEL=gpt-5.4-mini
OPENAI_CODEX_WORKDIR=.
# Safer default is read-only. Use workspace-write when you want Codex to edit this project.
OPENAI_CODEX_SANDBOX=read-only
# Last resort for machines where nested Codex sandboxing fails. Keep false unless trusted.
OPENAI_CODEX_BYPASS_SANDBOX=false
OPENAI_CODEX_TIMEOUT_SECONDS=900
OLLAMA_TIMEOUT_SECONDS=900
TELEGRAM_AGENT_TIMEOUT_SECONDS=900

# ==========================================
# Telegram Bot Configuration
# ==========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ==========================================
# Bot Configuration (Optional)
# ==========================================
DEFAULT_NETWORK=base
DEFAULT_CURRENCY=usd
MOCK_API=True  # Set to False to use real Trust Wallet API
DEBUG=False

# ==========================================
# MEV Protection & RPC Configuration
# ==========================================
# Use a private RPC or Flashbots-style endpoint to prevent front-running
# Base chain MEV RPC: https://mev.api.blxrbdn.com or similar
USE_MEV_PROTECTION=True
PRIVATE_RPC_URL=https://mainnet.base.org
MAX_SLIPPAGE_PCT=0.5
